# Neon Postgres — pooled connection URL from the Neon dashboard
DATABASE_URL=

# xAI Grok API (https://console.x.ai/)
XAI_API_KEY=

# Optional: Responses model id (default: grok-4-1-fast-non-reasoning — fastest/cheapest)
# XAI_MODEL=grok-4-1-fast-non-reasoning
# Fast with reasoning: grok-4-1-fast-reasoning
# Heavier: grok-4.20-0309-reasoning

# Optional: NationForge GM stream limits (defaults are high; lower if the API rejects max_output_tokens)
# NATIONFORGE_GM_MAX_OUTPUT_TOKENS=65536
# NATIONFORGE_GM_CONTINUATION_MAX_OUTPUT_TOKENS=32768
# NATIONFORGE_GM_CONTINUATION_MAX_ROUNDS=8

# Optional: default xAI TTS voice for NationForge when the client omits voice_id (eve | ara | leo | rex | sal)
# XAI_TTS_VOICE_ID=eve
